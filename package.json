{
  "name": "sn-sync",
  "publisher": "Alex Alvarez",
  "displayName": "sn-sync",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.snsyncrc"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "sn-sync",
      "properties": {
        "sn-sync.rootDir": {
          "type": "string",
          "default": "src",
          "description": "Root folder where sn-sync writes pulled files."
        },
        "sn-sync.pull.clearBeforePull": {
          "type": "string",
          "enum": [
            "ask",
            "delete",
            "keep"
          ],
          "default": "ask",
          "description": "Controls whether sn-sync asks, deletes, or keeps local files before pull commands."
        }
      }
    },
    "commands": [
      {
        "command": "sn-sync.sn-init",
        "title": "sn: init"
      },
      {
        "command": "sn-sync.auth",
        "title": "sn: auth"
      },
      {
        "command": "sn-sync.auth-validate",
        "title": "sn: auth validate"
      },
      {
        "command": "sn-sync.update-set.reset",
        "title": "sn: update set reset"
      },
      {
        "command": "sn-sync.pull",
        "title": "sn: pull"
      },
      {
        "command": "sn-sync.pull-table",
        "title": "sn: pull table"
      },
      {
        "command": "sn-sync.push-active",
        "title": "sn: push active"
      },
      {
        "command": "sn-sync.push-modified",
        "title": "sn: push modified"
      },
      {
        "command": "sn-sync.clear-src",
        "title": "sn: clear src"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "clean": "node -e \"require('node:fs').rmSync('out',{recursive:true,force:true})\"",
    "compile": "npm run clean && tsc -p ./ && tsc-alias -p tsconfig.json",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "coverage": "npm run pretest && node -e \"require('node:fs').rmSync('coverage',{recursive:true,force:true})\" && npx vscode-test --coverage --coverage-output coverage --coverage-reporter text-summary --coverage-reporter html"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1"
  }
}
